.env

# ── Version control ───────────────────────────────────────────────────────────
.git/
.gitignore

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Tests & Coverage ──────────────────────────────────────────────────────────
tests/
.pytest_cache/
htmlcov/
.coverage

# ── Docs / Local only ─────────────────────────────────────────────────────────
docs/
*.md

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
