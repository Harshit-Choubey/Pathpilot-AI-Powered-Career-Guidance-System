# =============================================================================
# PathPilot Backend — Environment Variables
# =============================================================================
# In Docker: these values are OVERRIDDEN by docker-compose.yml environment block.
# For local development (outside Docker): fill these in manually.
# =============================================================================

# App
PROJECT_NAME=PathPilot API
ENVIRONMENT=development
VERSION=v1

# Security
SECRET_KEY=change_me_to_a_long_random_string_in_production

# Database
# Local dev (outside Docker):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pathpilot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pathpilot

# Redis / Celery
# Local dev (outside Docker):
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ML service
# Local dev (outside Docker):
EXT_ML_SERVICE_URL=http://localhost:8001

# AI API Keys (required for AI chat and roadmap generation)
# Get Groq key at:   https://console.groq.com
# Get Gemini key at: https://aistudio.google.com/app/apikey
GROQ_API_KEY=
GEMINI_API_KEY=

# Access token expiry (in minutes) — 7 days default
ACCESS_TOKEN_EXPIRE_MINUTES=10080
