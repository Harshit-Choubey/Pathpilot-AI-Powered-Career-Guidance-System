APP_ENV=development
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pathpilot

# Used by backend + celery in Docker Compose
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/pathpilot
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
EXT_ML_SERVICE_URL=http://ml_service:8001

# Optional, but required for AI chat/roadmap generation
GROQ_API_KEY=
