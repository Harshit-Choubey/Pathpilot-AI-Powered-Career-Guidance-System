# =============================================================================
# PathPilot — Root Environment Variables
# =============================================================================
# SETUP:
#   cp .env.example .env
#   Fill in the required values below, then run:
#   docker compose up --build
#
# This file is read by docker-compose.yml at startup.
# NEVER commit the filled-in .env file to version control.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development

# Secret key for JWT signing — use a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_long_random_string_in_production

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pathpilot

# ── AI / External API Keys ────────────────────────────────────────────────────
# Required for AI roadmap generation and career chat.
# Get a FREE Groq key at:   https://console.groq.com
# Get a Gemini key at:      https://aistudio.google.com/app/apikey
GROQ_API_KEY=
GEMINI_API_KEY=

# ── Ports ─────────────────────────────────────────────────────────────────────
# Change FRONTEND_PORT if port 80 is already in use on your machine.
FRONTEND_PORT=80
